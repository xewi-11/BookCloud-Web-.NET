@model List<BookCloud.Models.Mensaje>
@{
    ViewData["Title"] = "Chat";
    var chatId = (int)ViewBag.ChatId;
    var usuarioActualId = (int)ViewBag.UsuarioActualId;
    var otroUsuario = (BookCloud.Models.Usuario)ViewBag.OtroUsuario;
    var libro = ViewBag.Libro as BookCloud.Models.Libro;
}

<style>
    /* Resetear estilos que puedan interferir */
    .container, .container-fluid {
        padding: 0 !important;
        max-width: 100% !important;
    }

    .chat-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
        margin-top: 1rem;
        margin-bottom: 1rem;
    }

    .chat-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 150px);
        min-height: 500px;
        max-height: 800px;
    }

    .chat-header {
        flex-shrink: 0;
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        color: var(--verde-fondo);
        padding: 1rem 1.5rem;
        border-bottom: 2px solid rgba(198, 167, 94, 0.3);
    }

    .chat-header h5 {
        color: var(--verde-fondo);
        font-weight: 700;
        margin: 0;
    }

    .chat-header small {
        color: rgba(11, 31, 26, 0.7);
    }

    .chat-header .btn-outline-light {
        border-color: var(--verde-fondo);
        color: var(--verde-fondo);
    }

    .chat-header .btn-outline-light:hover {
        background: var(--verde-fondo);
        color: var(--dorado);
    }

    .libro-info {
        background: rgba(11, 31, 26, 0.2);
        border-radius: 12px;
        padding: 0.6rem 1rem;
        transition: all 0.3s ease;
    }

    .libro-info:hover {
        background: rgba(11, 31, 26, 0.3);
        transform: scale(1.02);
    }

    .libro-info img {
        border: 2px solid var(--verde-fondo);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        background: linear-gradient(180deg, #0F2520 0%, #0B1F1A 100%);
        padding: 1.5rem;
    }

    .chat-input {
        flex-shrink: 0;
        background: var(--verde-card);
        border-top: 2px solid var(--dorado);
        padding: 1rem 1.5rem;
    }

    .chat-input .form-control {
        background: rgba(19, 47, 40, 0.5);
        border: 2px solid var(--dorado);
        color: var(--texto-claro);
        border-radius: 25px;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
    }

    .chat-input .form-control:focus {
        background: rgba(19, 47, 40, 0.7);
        border-color: var(--dorado-hover);
        box-shadow: 0 0 0 0.2rem rgba(198, 167, 94, 0.25);
        color: var(--texto-claro);
    }

    .chat-input .form-control::placeholder {
        color: var(--texto-secundario);
    }

    .chat-input .btn-primary {
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        border: none;
        box-shadow: 0 4px 12px rgba(198, 167, 94, 0.4);
    }

    .chat-input .btn-primary:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 16px rgba(198, 167, 94, 0.6);
    }

    .chat-input .btn-outline-warning {
        border: 2px solid var(--dorado);
        color: var(--dorado);
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: all 0.3s ease;
    }

    .chat-input .btn-outline-warning:hover {
        background: var(--dorado);
        color: var(--verde-fondo);
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(198, 167, 94, 0.6);
    }

    /* Estilos para mensajes con ubicación */
    .location-map {
        width: 100%;
        max-width: 350px;
        height: 250px;
        border-radius: 12px;
        overflow: hidden;
        margin-top: 0.5rem;
        border: 2px solid rgba(0, 0, 0, 0.3);
        background: #e0e0e0;
    }

    .location-link {
        display: inline-block;
        margin-top: 0.75rem;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .location-link:hover {
        background: rgba(255, 255, 255, 0.35);
        transform: translateY(-2px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .message-bubble.other .location-link {
        color: white;
    }

    .message-bubble.me .location-link {
        color: var(--verde-fondo);
    }

    /* Asegurar que los mapas de Leaflet se muestren correctamente */
    .location-map .leaflet-container {
        width: 100%;
        height: 100%;
    }

    /* Avatares de mensajes */
    .message-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.9rem;
        flex-shrink: 0;
        border: 2px solid var(--dorado);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .message-avatar.other {
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        color: white;
    }

    .message-avatar.me {
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        color: var(--verde-fondo);
    }

    /* Burbujas de mensajes */
    .message-bubble {
        max-width: 70%;
        padding: 0.875rem 1.25rem;
        border-radius: 18px;
        word-wrap: break-word;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        animation: fadeIn 0.3s ease;
    }

    .message-bubble.other {
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        color: white;
        border-bottom-left-radius: 4px;
    }

    .message-bubble.me {
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        color: var(--verde-fondo);
        border-bottom-right-radius: 4px;
    }

    .message-bubble p {
        margin: 0;
        line-height: 1.5;
    }

    .message-time {
        font-size: 0.75rem;
        opacity: 0.8;
        margin-top: 0.25rem;
    }

    .message-time.other {
        color: rgba(255, 255, 255, 0.7);
    }

    .message-time.me {
        color: rgba(11, 31, 26, 0.7);
    }

    /* Scrollbar personalizado */
    .chat-messages::-webkit-scrollbar {
        width: 10px;
    }

    .chat-messages::-webkit-scrollbar-track {
        background: rgba(19, 47, 40, 0.3);
        border-radius: 10px;
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: var(--dorado);
        border-radius: 10px;
        border: 2px solid var(--verde-fondo);
    }

    .chat-messages::-webkit-scrollbar-thumb:hover {
        background: var(--dorado-hover);
    }

    /* Estado vacío */
    .empty-chat {
        text-align: center;
        padding: 3rem 2rem;
        color: var(--texto-secundario);
    }

    .empty-chat i {
        font-size: 4rem;
        color: var(--dorado);
        opacity: 0.3;
        margin-bottom: 1rem;
    }

    /* Animación de fade in */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .chat-wrapper {
            border-radius: 0;
            margin: 0;
        }

        .chat-container {
            height: calc(100vh - 120px);
        }

        .libro-info {
            flex-direction: column !important;
            text-align: center;
        }

        .message-bubble {
            max-width: 85%;
        }
    }
</style>


<div class="chat-wrapper">
    <div class="chat-container">
        <!-- Header con información del libro -->
        <div class="chat-header">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <a href="@Url.Action("Index")" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    
                    <div>
                        <h5 class="mb-0">
                            <i class="bi bi-person-circle me-2"></i>@otroUsuario?.Nombre
                        </h5>
                        @if (libro != null)
                        {
                            <small>
                                <i class="bi bi-book"></i> @libro.Titulo
                            </small>
                        }
                    </div>
                </div>
                
                @* Foto del libro a la derecha *@
                @if (libro != null)
                {
                    <a asp-controller="Libro" asp-action="Details" asp-route-id="@libro.Id" 
                       class="text-decoration-none libro-info" title="Ver libro">
                        <div class="d-flex align-items-center gap-2">
                            <img src="~/imagenes/Libros/@libro.Foto" 
                                 alt="@libro.Titulo"
                                 class="rounded"
                                 style="width: 40px; height: 55px; object-fit: cover;">
                            <div>
                                <small class="d-block fw-bold" style="color: var(--verde-fondo);">@libro.Titulo</small>
                                <small class="d-block" style="color: var(--verde-fondo);">$@libro.Precio.ToString("N2")</small>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>

        <!-- Área de mensajes -->
        <div id="mensajesContainer" class="chat-messages">
            @if (Model.Any())
            {
                @foreach (var mensaje in Model)
                {
                    var esMio = mensaje.RemitenteId == usuarioActualId;
                    <div class="d-flex mb-3 @(esMio ? "justify-content-end" : "justify-content-start")" data-mensaje-id="@mensaje.Id">
                        @if (!esMio)
                        {
                            <div class="message-avatar other me-2" style="align-self: end;">
                                @otroUsuario?.Nombre?.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <div class="message-bubble @(esMio ? "me" : "other")">
                            @if (!string.IsNullOrWhiteSpace(mensaje.Contenido))
                            {
                                <p>@mensaje.Contenido</p>
                            }
                            @if (mensaje.TieneUbicacion && mensaje.Latitud.HasValue && mensaje.Longitud.HasValue)
                            {
                                <div class="location-map" 
                                     id="map-@mensaje.Id"
                                     data-lat="@mensaje.Latitud.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                                     data-lng="@mensaje.Longitud.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"></div>
                                <a href="https://www.google.com/maps?q=@mensaje.Latitud.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@mensaje.Longitud.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                                   target="_blank" 
                                   class="location-link">
                                    <i class="bi bi-map"></i> Ver en Google Maps
                                </a>
                            }
                            <small class="message-time @(esMio ? "me" : "other") d-block text-end">
                                @mensaje.FechaEnvio.ToString("HH:mm")
                            </small>
                        </div>
                        @if (esMio)
                        {
                            @* 🆕 MIGRADO A CLAIMS: Obtener nombre desde Claims *@
                            var miNombre = User.Identity?.Name ?? "";
                            <div class="message-avatar me ms-2" style="align-self: end;">
                                @(string.IsNullOrEmpty(miNombre) ? "?" : miNombre.Substring(0, 1).ToUpper())
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-chat">
                    <i class="bi bi-chat-dots"></i>
                    <p class="mt-3">No hay mensajes aún</p>
                    <p class="text-muted small">¡Inicia la conversación!</p>
                </div>
            }
        </div>

        <!-- Input de mensaje -->
        <div class="chat-input">
            <form id="formMensaje" class="d-flex gap-2 align-items-center">
                <button type="button" 
                        id="btnCompartirUbicacion" 
                        class="btn btn-outline-warning"
                        title="Compartir ubicación">
                    <i class="bi bi-geo-alt-fill"></i>
                </button>
                <input type="text" 
                       id="inputMensaje" 
                       class="form-control" 
                       placeholder="Escribe un mensaje..."
                       autocomplete="off"
                       maxlength="500"
                       required>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send-fill"></i>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        const chatId = @chatId;
        const usuarioActualId = @usuarioActualId;
        const otroUsuarioNombre = "@otroUsuario?.Nombre";
        // 🆕 MIGRADO A CLAIMS: Obtener nombre desde Claims en lugar de Session
        const miNombre = "@User.Identity.Name";

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("RecibirMensaje", (mensaje) => {
            agregarMensajeAlDOM(mensaje);
        });

        connection.start()
            .then(() => {
                console.log("✅ Conectado a SignalR");
                connection.invoke("UnirseAlChat", chatId);
            })
            .catch(err => {
                console.error("❌ Error al conectar:", err);
                alert("Error de conexión. Recarga la página.");
            });

        connection.onreconnecting(() => {
            console.log("🔄 Reconectando...");
        });

        connection.onreconnected(() => {
            console.log("✅ Reconectado");
            connection.invoke("UnirseAlChat", chatId);
        });

        document.getElementById("formMensaje").addEventListener("submit", async (e) => {
            e.preventDefault();
            
            const input = document.getElementById("inputMensaje");
            const contenido = input.value.trim();
            
            if (contenido && connection.state === signalR.HubConnectionState.Connected) {
                try {
                    await connection.invoke("EnviarMensaje", chatId, usuarioActualId, contenido);
                    input.value = "";
                    input.focus();
                } catch (err) {
                    console.error("❌ Error al enviar mensaje:", err);
                    alert("Error al enviar el mensaje. Intenta de nuevo.");
                }
            }
        });

        document.getElementById("btnCompartirUbicacion").addEventListener("click", async () => {
            if (!navigator.geolocation) {
                alert("Tu navegador no soporta geolocalización");
                return;
            }

            const btn = document.getElementById("btnCompartirUbicacion");
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

            navigator.geolocation.getCurrentPosition(
                async (position) => {
                    try {
                        const latitud = position.coords.latitude;
                        const longitud = position.coords.longitude;

                        await connection.invoke("EnviarUbicacion", chatId, usuarioActualId, latitud, longitud);
                        
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i>';
                    } catch (err) {
                        console.error("❌ Error al enviar ubicación:", err);
                        alert("Error al enviar la ubicación. Intenta de nuevo.");
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i>';
                    }
                },
                (error) => {
                    console.error("❌ Error de geolocalización:", error);
                    let mensaje = "No se pudo obtener tu ubicación. ";
                    
                    switch(error.code) {
                        case error.PERMISSION_DENIED:
                            mensaje += "Debes permitir el acceso a tu ubicación.";
                            break;
                        case error.POSITION_UNAVAILABLE:
                            mensaje += "La información de ubicación no está disponible.";
                            break;
                        case error.TIMEOUT:
                            mensaje += "La solicitud ha excedido el tiempo de espera.";
                            break;
                    }
                    
                    alert(mensaje);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i>';
                }
            );
        });

        function agregarMensajeAlDOM(mensaje) {
            const container = document.getElementById("mensajesContainer");
            const esMio = mensaje.remitenteId === usuarioActualId;
            
            const inicial = esMio ? miNombre.substring(0, 1).toUpperCase() : otroUsuarioNombre.substring(0, 1).toUpperCase();
            const avatarClass = esMio ? 'me' : 'other';
            const bubbleClass = esMio ? 'me' : 'other';
            const timeClass = esMio ? 'me' : 'other';
            const justifyClass = esMio ? 'justify-content-end' : 'justify-content-start';
            
            const mapId = `map-${mensaje.id}`;
            let locationHTML = '';
            let contenidoHTML = '';
            
            // Solo mostrar el contenido si no está vacío
            if (mensaje.contenido && mensaje.contenido.trim() !== '') {
                contenidoHTML = `<p>${escapeHtml(mensaje.contenido)}</p>`;
            }
            
            if (mensaje.tieneUbicacion && mensaje.latitud && mensaje.longitud) {
                const linkColor = esMio ? 'color: var(--verde-fondo);' : 'color: white;';
                locationHTML = `
                    <div class="location-map" 
                         id="${mapId}"
                         data-lat="${mensaje.latitud}" 
                         data-lng="${mensaje.longitud}"></div>
                    <a href="https://www.google.com/maps?q=${mensaje.latitud},${mensaje.longitud}" 
                       target="_blank" 
                       class="location-link"
                       style="${linkColor}">
                        <i class="bi bi-map"></i> Ver en Google Maps
                    </a>
                `;
            }
            
            const mensajeHTML = `
                <div class="d-flex mb-3 ${justifyClass}" data-mensaje-id="${mensaje.id}">
                    ${!esMio ? `<div class="message-avatar other me-2" style="align-self: end;">${inicial}</div>` : ''}
                    <div class="message-bubble ${bubbleClass}">
                        ${contenidoHTML}
                        ${locationHTML}
                        <small class="message-time ${timeClass} d-block text-end">
                            ${mensaje.fechaEnvio}
                        </small>
                    </div>
                    ${esMio ? `<div class="message-avatar me ms-2" style="align-self: end;">${inicial}</div>` : ''}
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', mensajeHTML);
            
            // Si el mensaje tiene ubicación, inicializar el mapa
            if (mensaje.tieneUbicacion && mensaje.latitud && mensaje.longitud) {
                setTimeout(() => {
                    const mapElement = document.getElementById(mapId);
                    if (mapElement && !mapElement._leaflet_id) {
                        try {
                            const map = L.map(mapId, {
                                center: [mensaje.latitud, mensaje.longitud],
                                zoom: 15,
                                scrollWheelZoom: false
                            });
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '&copy; OpenStreetMap contributors'
                            }).addTo(map);
                            L.marker([mensaje.latitud, mensaje.longitud]).addTo(map);
                        } catch (error) {
                            console.error('Error inicializando mapa:', error);
                        }
                    }
                }, 100);
            }
            
            scrollToBottom();
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function scrollToBottom() {
            const container = document.getElementById("mensajesContainer");
            container.scrollTop = container.scrollHeight;
        }

        function inicializarMapas() {
            // Inicializar todos los mapas existentes en la página
            document.querySelectorAll('.location-map').forEach(mapElement => {
                const mapId = mapElement.id;
                const lat = parseFloat(mapElement.getAttribute('data-lat'));
                const lng = parseFloat(mapElement.getAttribute('data-lng'));
                
                if (!isNaN(lat) && !isNaN(lng)) {
                    try {
                        // Verificar si el mapa ya está inicializado
                        if (mapElement._leaflet_id) {
                            return; // Ya está inicializado
                        }
                        
                        const map = L.map(mapId, {
                            center: [lat, lng],
                            zoom: 15,
                            scrollWheelZoom: false
                        });
                        
                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '&copy; OpenStreetMap contributors'
                        }).addTo(map);
                        
                        L.marker([lat, lng]).addTo(map);
                    } catch (error) {
                        console.error(`Error inicializando mapa ${mapId}:`, error);
                    }
                }
            });
        }

        window.addEventListener('load', () => {
            scrollToBottom();
            // Inicializar mapas después de un pequeño delay para asegurar que Leaflet esté cargado
            setTimeout(inicializarMapas, 100);
        });
    </script>
}